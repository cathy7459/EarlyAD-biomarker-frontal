cor_with_pc <- function(x, y) suppressWarnings(cor(x, y, use = "pairwise.complete.obs"))

Cmat <- sapply(1:ncol(scores), function(k) {
  apply(X_all, 2, function(g) cor_with_pc(g, scores[, k]))
})
