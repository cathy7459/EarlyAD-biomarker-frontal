## =========================
## 2) 부분상관 PCmat (genes x K_used)
##    - gene와 PCk 각각을 다른 PC들에 회귀 -> 잔차끼리 상관
## =========================
partial_cor_onegene <- function(g, S) {
  K <- ncol(S)
  out <- rep(NA_real_, K)
  for (k in 1:K) {
    if (K == 1) {
      out[k] <- suppressWarnings(cor(g, S[, k], use = "pairwise.complete.obs"))
    } else {
      others <- S[, -k, drop = FALSE]
      rg <- residuals(lm(g ~ others))
      rk <- residuals(lm(S[, k] ~ others))
      out[k] <- suppressWarnings(cor(rg, rk, use = "pairwise.complete.obs"))
    }
  }
  out
}

PCmat <- t(apply(X_all, 2, partial_cor_onegene, S = scores))  # genes x K_used
rownames(PCmat) <- colnames(X_all)

## =========================
## 3) "AND" 조건(>= m PCs 만족) 유지하되,
##    thr_p, thr_s를 자동으로 찾기 (0개 방지)
## =========================
m <- 2  # 너가 원한 AND 강도 유지

# 후보 임계값 그리드: 상관 분포를 보고 자동으로 탐색
grid_p <- seq(0.60, 0.20, by = -0.02)  # 부분상관은 보통 작아서 더 낮은 범위까지
grid_s <- seq(0.80, 0.30, by = -0.02)  # 단순상관은 더 크게 나오는 편

target_max <- 800
core_n <- length(unique(core_features))

best <- NULL

for (thr_p in grid_p) {
  pass_p <- rowSums(abs(PCmat) >= thr_p, na.rm = TRUE) >= m
  if (sum(pass_p) == 0) next
  
  for (thr_s in grid_s) {
    pass_s <- rowSums(abs(Cmat) >= thr_s, na.rm = TRUE) >= m
    keep1 <- pass_p & pass_s
    
    # core는 항상 포함이라 union 기준으로 본다
    nn <- length(union(rownames(expr_gene), rownames(Cmat)[keep1]))
    
    # 0개 방지: 최소 후보가 core 외에도 조금은 있어야 함
    if (nn > core_n && nn <= target_max) {
      best <- list(thr_p = thr_p, thr_s = thr_s, nn = nn, keep1 = keep1)
      break
    }
  }
  if (!is.null(best)) break
}

# 만약 target_max 이하로 못 맞추면, "가장 가까운(최소 초과)" 조합을 찾음
if (is.null(best)) {
  best_dist <- Inf
  best <- list(thr_p = NA_real_, thr_s = NA_real_, nn = NA_integer_, keep1 = rep(FALSE, nrow(Cmat)))
  
  for (thr_p in grid_p) {
    pass_p <- rowSums(abs(PCmat) >= thr_p, na.rm = TRUE) >= m
    if (sum(pass_p) == 0) next
    
    for (thr_s in grid_s) {
      pass_s <- rowSums(abs(Cmat) >= thr_s, na.rm = TRUE) >= m
      keep1 <- pass_p & pass_s
      nn <- length(union(rownames(expr_gene), rownames(Cmat)[keep1]))
      
      # 목표(<=800)를 최우선, 불가능하면 초과량 최소
      dist <- if (nn <= target_max) (target_max - nn) else (nn - target_max)
      if (dist < best_dist && nn > core_n) {
        best_dist <- dist
        best <- list(thr_p = thr_p, thr_s = thr_s, nn = nn, keep1 = keep1)
      }
    }
  }
}

cat("Chosen thresholds: thr_p =", best$thr_p, "thr_s =", best$thr_s, "\n")
cat("Genes after AND filter (including core union):", best$nn, "\n")

