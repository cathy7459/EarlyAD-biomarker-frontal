for (i in seq_len(ncol(datExpr))) {
  mc <- me_for_gene[i]
  if (is.na(mc)) next
  absKME_own[i] <- abs(suppressWarnings(cor(datExpr[, i], MEs[, mc], use = "pairwise.complete.obs")))
}

