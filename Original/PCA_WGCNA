me_cols <- colnames(MEs)

get_me_col <- function(mod) {
  cand <- paste0("ME", mod)
  if (cand %in% me_cols) return(cand)
  return(NA_character_)
}
me_for_gene <- vapply(module_id, get_me_col, character(1))

