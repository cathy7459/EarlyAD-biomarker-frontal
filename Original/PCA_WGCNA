if (!is.null(rownames(datExpr)) && !is.null(rownames(MEs))) {
  common_samp <- intersect(rownames(datExpr), rownames(MEs))
  datExpr <- datExpr[common_samp, , drop = FALSE]
  MEs     <- MEs[common_samp, , drop = FALSE]
} else {
  if (nrow(datExpr) != nrow(MEs)) stop("datExpr와 MEs의 샘플 수가 달라요(rownames 정렬 필요).")
}

