# =========================
# 2) Read GSE33000 series matrix table
#    - series matrix 안에서 !series_matrix_table_begin ~ end 구간만 읽기
# =========================
read_series_matrix_table <- function(gzfile) {
  con <- gzfile(gzfile, open = "rt")
  on.exit(close(con), add = TRUE)
  
  # begin 찾기
  line <- ""
  while(length(line) > 0) {
    line <- readLines(con, n = 1)
    if (length(line) == 0) break
    if (grepl("^!series_matrix_table_begin", line)) break
  }
  
  # header line: "ID_REF"  "GSM..."
  header <- readLines(con, n = 1)
  header <- gsub('^"|"$', "", header)
  header <- strsplit(header, "\t")[[1]]
  header <- gsub('"', "", header)
  
  # table end 전까지 읽기
  lines <- character()
  repeat {
    x <- readLines(con, n = 5000)
    if (length(x) == 0) break
    end_idx <- which(grepl("^!series_matrix_table_end", x))
    if (length(end_idx) > 0) {
      lines <- c(lines, x[seq_len(end_idx[1]-1)])
      break
    } else {
      lines <- c(lines, x)
    }
  }
  
  dt <- fread(text = paste(lines, collapse = "\n"), sep = "\t", header = FALSE)
  setnames(dt, header)
  return(dt)
}

