cat("Core genes observed in GSE33000:", length(unique(m_core$GeneSymbol)), "\n")

# =========================
# 5) Multiple probes per gene -> collapse
#    기본: 각 GeneSymbol마다 '분산이 가장 큰 프로브' 1개 선택
#    (LASSO에 넣을 때 가장 information-rich인 경우가 많음)
# =========================
sample_cols <- setdiff(colnames(m_core), c("ID_REF", "GeneSymbol"))

# 분산 계산
m_core[, probe_var := apply(.SD, 1, var, na.rm = TRUE), .SDcols = sample_cols]

setorder(m_core, GeneSymbol, -probe_var)
m_best <- m_core[, .SD[1], by = GeneSymbol]  # gene당 1개 프로브

# matrix 형태로 변환
expr_core <- as.data.frame(m_best[, ..sample_cols])
rownames(expr_core) <- m_best$GeneSymbol

