)

# GeneSymbol 정리: 여러 심볼이 묶인 경우 분리(보통 ' /// ' 같은 구분자 사용)
clean_symbol <- function(x) {
  x <- gsub('"', "", x)
  x <- trimws(x)
  # 흔한 구분자들 처리: " /// ", ";", ","
  x <- strsplit(x, " /// |;|,")[[1]][1]
  x <- trimws(x)
  if (is.na(x) || x == "" || x == "---") return(NA_character_)
  return(x)
}
anno[, GeneSymbol := vapply(GeneSymbol_raw, clean_symbol, character(1))]
