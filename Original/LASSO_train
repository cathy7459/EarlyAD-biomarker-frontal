# =========================
gpl <- getGEO("GPL4372", AnnotGPL = TRUE)
gpl_tab <- Table(gpl)

# 여러 플랫폼에서 Gene Symbol 컬럼명이 제각각이라 robust하게 찾기
sym_col_candidates <- c("Gene Symbol", "Gene symbol", "GENE_SYMBOL", "Symbol", "SYMBOL", "gene_assignment")
id_col_candidates  <- c("ID", "ID_REF", "Probe", "PROBE_ID", "probe_id")

pick_col <- function(cols, candidates) {
  hit <- candidates[candidates %in% cols]
  if (length(hit) > 0) return(hit[1])
  # 부분매칭도 시도
  for (cand in candidates) {
    idx <- which(tolower(cols) == tolower(cand))
    if (length(idx) > 0) return(cols[idx[1]])
  }
  return(NA_character_)
}

id_col  <- pick_col(colnames(gpl_tab), id_col_candidates)
sym_col <- pick_col(colnames(gpl_tab), sym_col_candidates)

if (is.na(id_col) || is.na(sym_col)) {
  stop("GPL4372 annotation에서 ID / GeneSymbol 컬럼을 못 찾았어. gpl_tab colnames를 확인해줘.")
}

anno <- data.table(
