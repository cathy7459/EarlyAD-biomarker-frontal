make_labels_gse33000_v2 <- function(meta_dt) {
  fields <- setdiff(names(meta_dt), "GSM")
  row_text <- apply(meta_dt[, ..fields], 1, function(x) paste(na.omit(as.character(x)), collapse=" | "))
  
  # HD 먼저 제외
  is_hd <- grepl("(huntington|\\bHD\\b)", row_text, ignore.case=TRUE, perl=TRUE)
  
  # AD: 'AD' 단독 토큰은 오탐이 꽤 있어서, alzheimer 중심으로 잡는 게 안전
  is_ad <- grepl("(alzheimer|alzheimers|alzheimer\\'s\\s*disease|\\bLOAD\\b)", row_text,
                 ignore.case=TRUE, perl=TRUE)
  
  # Control/정상: 표현 다양해서 키워드 넓게
  is_ctl <- grepl("(control|normal\\b|healthy|\\bND\\b|non\\s*-?dement(ed|ia)?|no\\s*dement(ed|ia)?|unaffected|no\\s*AD)",
                  row_text, ignore.case=TRUE, perl=TRUE)
  
  y <- rep(NA_character_, nrow(meta_dt))
  y[is_hd] <- "HD"
  
  # 우선순위: AD 먼저, 그 다음 Control
  y[!is_hd & is_ad] <- "AD"
  y[!is_hd & !is_ad & is_ctl] <- "Control"
  
  data.table(GSM = meta_dt$GSM, y = y, row_text = row_text)
}

