    paste(colnames(gpl_tbl), collapse = ", ")
  )
}

## 3) gene symbol 정리 함수 (다중 기호/구분자 처리)
clean_symbol <- function(x) {
  x <- as.character(x)
  x <- trimws(x)
  x[x == "" | is.na(x)] <- NA_character_
  
  # "A /// B", "A;B", "A,B" -> 첫 토큰만 사용
  x <- stringr::str_split_fixed(x, "\\s*///\\s*|\\s*;\\s*|\\s*,\\s*", 2)[, 1]
  x <- trimws(x)
  x[x == "" | is.na(x)] <- NA_character_
  return(x)
}

## 4) probe -> symbol 매핑 테이블 생성
##    - gpl_tbl의 1번째 컬럼이 probe ID인 경우가 많아서 기본으로 사용
probe_id_col <- colnames(gpl_tbl)[1]

map_df <- gpl_tbl %>%
  dplyr::select(probe = dplyr::all_of(probe_id_col),
                symbol_raw = dplyr::all_of(symbol_col)) %>%
  dplyr::mutate(symbol = clean_symbol(symbol_raw)) %>%
  dplyr::filter(!is.na(symbol))

## 5) expr_probe_f와 매칭 (매핑되는 probe만 남기기)
expr_probe_f<-expr_f2
probe_ids <- rownames(expr_probe_f)
map_df <- map_df %>% dplyr::filter(probe %in% probe_ids)

if (nrow(map_df) == 0) {
  stop("expr_f2의 probe ID와 GPL의 probe ID가 매칭되지 않았어요. (probe_id_col이 맞는지 확인 필요)")
}

# expr을 매핑된 probe 순서로 재정렬
expr_mapped <- expr_probe_f[map_df$probe, , drop = FALSE]

## 6) 중복 gene 처리: 같은 symbol을 갖는 여러 probe를 gene 단위로 collapse(평균)
##    결과: expr_gene (gene x sample)
expr_gene <- limma::avereps(expr_mapped, ID = map_df$symbol)

## 확인
