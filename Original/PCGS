# ----------------------------
pick_col <- function(df, patterns, required = TRUE) {
  cn <- colnames(df)
  hit <- NULL
  for (p in patterns) {
    idx <- which(str_detect(tolower(cn), p))
    if (length(idx) > 0) { hit <- cn[idx[1]]; break }
  }
  if (is.null(hit) && required) {
    stop(
      "컬럼을 못 찾았어요. patterns=", paste(patterns, collapse="|"),
      "\n현재 컬럼: ", paste(colnames(df), collapse=", ")
    )
  }
  hit
}

normalize_group <- function(x) {
  x0 <- tolower(trimws(as.character(x)))
  x0 <- str_replace_all(x0, "\\s+", "")
  dplyr::case_when(
    str_detect(x0, "control|ctl|normal|nonad|healthy") ~ "Control",
    str_detect(x0, "asym") ~ "AsymAD",
    str_detect(x0, "^ad$|alzheimer|symad|dementia") ~ "AD",
    TRUE ~ NA_character_
  )
}

get_deg <- function(fit_obj, coef_name, fdr = 0.05, lfc = log2(1.2)) {
  topTable(fit_obj, coef = coef_name, number = Inf, sort.by = "P") %>%
    rownames_to_column("feature") %>%
    as_tibble() %>%
    filter(adj.P.Val < fdr, abs(logFC) >= lfc)
}

# ----------------------------
# 1) GSE118553 불러오기
# ----------------------------
gse_id <- "GSE118553"
gset_list <- getGEO(gse_id, GSEMatrix = TRUE, getGPL = FALSE)
gset <- gset_list[[1]]

expr <- exprs(gset)   # features x samples
pdat <- pData(gset)

# group / region 컬럼 자동 추정
group_col  <- pick_col(pdat, c("disease", "diagnos", "status", "group", "phenotype", "characteristics"))
region_col <- pick_col(pdat, c("region", "brain", "tissue", "area", "cortex", "pfc", "brodmann"), required = FALSE)

if (is.null(region_col)) {
  stop("뇌 영역(region) 컬럼을 찾지 못했어요. pData(gset) 컬럼 확인 후 region_col을 직접 지정해야 해요.")
}

# ----------------------------
# 2) group 라벨 만들고 NA 제거
# ----------------------------
group <- normalize_group(pdat[[group_col]])
keep <- !is.na(group)

expr <- expr[, keep, drop = FALSE]
pdat <- pdat[keep, , drop = FALSE]
group <- factor(group[keep], levels = c("Control", "AsymAD", "AD"))

# ----------------------------
# 3) Frontal 샘플만 남기기
# ----------------------------
region_text <- tolower(as.character(pdat[[region_col]]))

# frontal 매칭 규칙 (필요 시 키워드 더/덜 추가 가능)
is_frontal <- str_detect(region_text, "frontal|pfc|prefrontal|dlpfc|dorsolateral")

cat("=== Region top counts ===\n")
print(sort(table(region_text), decreasing = TRUE)[1:min(20, length(table(region_text)))])

cat("\nFrontal matched samples:", sum(is_frontal), "/", length(is_frontal), "\n")

expr_f <- expr[, is_frontal, drop = FALSE]
pdat_f <- pdat[is_frontal, , drop = FALSE]
group_f <- droplevels(group[is_frontal])

cat("\n=== Group counts (frontal only) ===\n")
print(table(group_f))

if (any(table(group_f) < 3)) {
  warning("frontal subset에서 어떤 그룹이 너무 적을 수 있어요. (DE 안정성 저하)")
}

# ----------------------------
# 4) (권장) 저발현/저변동 필터
# ----------------------------
q25 <- quantile(expr_f, probs = 0.25, na.rm = TRUE)
min_n <- ceiling(ncol(expr_f) * 0.20)
keep_expr <- rowSums(expr_f > q25) >= min_n

v <- rowVars(expr_f, na.rm = TRUE)
keep_var <- v > quantile(v, 0.10, na.rm = TRUE)

expr_f2 <- expr_f[keep_expr & keep_var, , drop = FALSE]
cat("\nRemaining features after filter:", nrow(expr_f2), "\n")

# ----------------------------
# 5) limma로 3개 contrast DEG
# ----------------------------
design <- model.matrix(~ 0 + group_f)
colnames(design) <- make.names(colnames(design))

fit <- lmFit(expr_f2, design)

ct <- makeContrasts(
  group1_AsymAD_vs_Control = group_fAsymAD - group_fControl,  # group1
  group2_AD_vs_Control     = group_fAD - group_fControl,      # group2
  group3_AD_vs_AsymAD      = group_fAD - group_fAsymAD,       # group3
  levels = design
)

fit2 <- eBayes(contrasts.fit(fit, ct))

# DE 기준
FDR <- 0.05
LFC <- log2(1.2)

deg_g1 <- get_deg(fit2, "group1_AsymAD_vs_Control", fdr = FDR, lfc = LFC)
deg_g2 <- get_deg(fit2, "group2_AD_vs_Control",     fdr = FDR, lfc = LFC)
deg_g3 <- get_deg(fit2, "group3_AD_vs_AsymAD",      fdr = FDR, lfc = LFC)

cat("\n=== DEG counts ===\n")
cat("group1 (AsymAD vs Control):", nrow(deg_g1), "\n")
cat("group2 (AD vs Control):    ", nrow(deg_g2), "\n")
cat("group3 (AD vs AsymAD):     ", nrow(deg_g3), "\n")

# ----------------------------
# 6) 네 규칙: group1 중 group2 또는 group3와 겹치는 것만
# core = DEG(group1) ∩ (DEG(group2) ∪ DEG(group3))
# ----------------------------
core_features <- intersect(deg_g1$feature, union(deg_g2$feature, deg_g3$feature))
cat("\nPreclinical core features (group1 overlap with group2 or group3):",
    length(core_features), "\n")

# ----------------------------
