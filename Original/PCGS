##PCA를 위한 마지막 전처리

## 전제:
## core_features : probe ID 157개
## map_df        : probe-symbol 매핑 테이블 (columns: probe, symbol)
## expr_gene     : gene x sample matrix (이미 collapse 완료)

# 1) probe core를 gene symbol로 변환 (core_features 덮어씀)
core_features <- map_df$symbol[match(core_features, map_df$probe)]
core_features <- unique(core_features[!is.na(core_features)])

# 확인
length(core_features)   # 이제 "gene symbol" 개수 (보통 157보다 줄어듦)

# 2) expr_gene에서 해당 gene들만 남기기 (expr_gene 덮어씀)
