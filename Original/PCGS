# 3) 엑셀용: gene symbol을 첫 컬럼으로
expr_gene <- tibble::rownames_to_column(
  as.data.frame(expr_gene),
  var = "GeneSymbol"
)

# 4) 엑셀 저장 (이미 설치된 패키지만 사용)
if (requireNamespace("openxlsx", quietly = TRUE)) {
  openxlsx::write.xlsx(expr_gene, file = "PCGS_gse118553.xlsx")
} else if (requireNamespace("writexl", quietly = TRUE)) {
