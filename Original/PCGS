  warning("엑셀 패키지가 없어 CSV로 저장됨: PCGS_gse118553.csv")
}

##PCA expansion

expr_gene_all <- limma::avereps(expr_mapped, ID = map_df$symbol)


## ==========
## 0) (필요할 때만) expr_gene가 data.frame(GeneSymbol 컬럼 포함)으로 변해버린 경우 복구
## ==========
if (is.data.frame(expr_gene) && "GeneSymbol" %in% colnames(expr_gene)) {
  rownames(expr_gene) <- expr_gene$GeneSymbol
  expr_gene$GeneSymbol <- NULL
  expr_gene <- as.matrix(expr_gene)
}

## ==========
## 1) PCA: core geneset(expr_gene)로 PC space 만들기
##    - samples x genes 형태로 변환 후 scale
## ==========
X <- t(expr_gene)                 # samples x genes
X <- scale(X)                     # 표준화

pca <- prcomp(X, center = TRUE, scale. = TRUE)

## 누적 설명분산 기준으로 사용할 PC 개수 K 결정 (기본 80%)
pc_cumvar <- 0.80
var_expl <- (pca$sdev^2) / sum(pca$sdev^2)
cumvar <- cumsum(var_expl)
K <- which(cumvar >= pc_cumvar)[1]
K <- max(2, K)                    # 최소 2개 PC

scores <- pca$x[, 1:K, drop = FALSE]   # samples x K

cat("PCA PCs used K =", K, " / cumvar =", round(cumvar[K], 3), "\n")

## ==========
## 2) 확장 후보 공간(전체 유전자)을 준비
##    - 여기서 필요한 건 '전체 유전자 행렬'임
##    - 지금 expr_gene는 core만 남긴 상태라서,
##      전체 유전자 행렬을 가지고 있다면 그 이름을 써야 함.
##
##    가장 흔한 경우:
##    - 너는 이전 단계에서 전체 유전자 행렬을 expr_gene_f / expr_gene_all 같은 이름으로 저장해뒀을 수 있음.
##    - 만약 전체 유전자 행렬이 따로 없다면, PCA expansion은 core 밖으로 확장이 불가능함.
## ==========
## 아래에서 전체 유전자 행렬 이름을 'expr_gene_all'로 가정하고 사용.
## 네 환경에서 이름이 다르면 그 한 줄만 바꿔서 쓰면 됨.

if (!exists("expr_gene_all")) {
  stop("PCA expansion을 하려면 '전체 유전자 행렬'이 필요해요.\n",
       "현재 expr_gene는 core만 남아있어서 core 밖으로 확장할 수 없습니다.\n",
       "이전에 만들어둔 전체 gene-level matrix(예: expr_gene_f / expr_gene_full 등)를 expr_gene_all로 지정해 주세요.\n\n",
       "예: expr_gene_all <- <전체 유전자 행렬 객체>")
}

## 전체 유전자 행렬(genes x samples)에서 samples 순서가 동일한지 확인/정렬
expr_gene_all <- expr_gene_all[, colnames(expr_gene), drop = FALSE]

## samples x genes
Xall <- t(expr_gene_all)
Xall <- scale(Xall)

## ==========
## 3) 각 유전자에 대해: 선택된 PC들과의 상관 중 최대 |cor| 계산
## ==========
cor_with_pc <- function(x, y) suppressWarnings(cor(x, y, use = "pairwise.complete.obs"))

genes <- colnames(Xall)
max_abs_cor <- rep(NA_real_, length(genes))

for (j in seq_along(genes)) {
  cj <- sapply(1:ncol(scores), function(k) cor_with_pc(Xall[, j], scores[, k]))
  max_abs_cor[j] <- max(abs(cj), na.rm = TRUE)
}

## ==========
## 4) |cor| 임계값을 자동으로 골라 확장 유전자 수를 적정 범위로 맞춤
##    - 기본 목표: 200~800개 (샘플 적으면 120~400)
## ==========
n_samples <- nrow(Xall)
target_min <- ifelse(n_samples < 120, 120, 200)
target_max <- ifelse(n_samples < 120, 400, 800)

cor_grid <- seq(0.60, 0.15, by = -0.01)

best_thr <- NA_real_
best_n <- NA_integer_

for (thr in cor_grid) {
  expanded <- genes[which(max_abs_cor >= thr)]
  expanded <- union(expanded, rownames(expr_gene))  # core는 무조건 포함
  nn <- length(expanded)
  if (nn >= target_min && nn <= target_max) {
    best_thr <- thr; best_n <- nn
    break
  }
}

if (is.na(best_thr)) {
  cand_n <- sapply(cor_grid, function(thr) {
    expanded <- genes[which(max_abs_cor >= thr)]
    length(union(expanded, rownames(expr_gene)))
  })
  dist <- ifelse(cand_n < target_min, target_min - cand_n,
                 ifelse(cand_n > target_max, cand_n - target_max, 0))
  idx <- which.min(dist)
  best_thr <- cor_grid[idx]
  best_n <- cand_n[idx]
}

cat("Chosen |cor| threshold =", best_thr, "\n")
cat("Expanded gene count     =", best_n, "\n")

## ==========
## 5) 확장 geneset을 core_features에 덮어쓰기 + expr_gene도 확장 세트로 덮어쓰기
## ==========
core_features <- unique(union(rownames(expr_gene), genes[which(max_abs_cor >= best_thr)]))

## expr_gene을 확장 유전자 행렬(genes x samples)로 덮어씀
expr_gene <- expr_gene_all[core_features, , drop = FALSE]

cat("Final expanded genes (core_features):", length(core_features), "\n")
cat("expr_gene dim:", dim(expr_gene)[1], "x", dim(expr_gene)[2], "\n")


