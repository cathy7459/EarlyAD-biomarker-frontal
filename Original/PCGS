## 2) GPL 테이블에서 gene symbol 컬럼 자동 탐색
pick_symbol_col_from_gpl <- function(gpl_tbl) {
  cn <- colnames(gpl_tbl)
  c0 <- tolower(cn)
  
  idx1 <- which(
    c0 %in% c("gene symbol","genesymbol","symbol") |
      stringr::str_detect(c0, "gene\\s*symbol") |
      stringr::str_detect(c0, "\\bsymbol\\b")
  )
  if (length(idx1) > 0) return(cn[idx1[1]])
  
  idx2 <- which(stringr::str_detect(c0, "gene") & stringr::str_detect(c0, "symbol"))
  if (length(idx2) > 0) return(cn[idx2[1]])
  
  return(NA_character_)
}

symbol_col <- pick_symbol_col_from_gpl(gpl_tbl)
if (is.na(symbol_col)) {
  stop(
    "GPL 테이블에서 gene symbol 컬럼을 자동으로 못 찾았어요.\n",
