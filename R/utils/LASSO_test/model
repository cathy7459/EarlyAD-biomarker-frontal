suppressPackageStartupMessages({
  library(data.table)
  library(glmnet)
  library(pROC)
})

fit_lasso_cv <- function(X_train, y_train, alpha = 1, nfolds = 10) {
  cv.glmnet(
    x = X_train,
    y = y_train,
    family = "binomial",
    alpha = alpha,
    nfolds = nfolds,
    type.measure = "auc"
  )
}

extract_coefficients <- function(cvfit, lambda_use) {
  coef_mat <- coef(cvfit, s = lambda_use)
  coef_dt <- data.table(
    GeneSymbol = rownames(coef_mat),
    Coef = as.numeric(coef_mat)
  )
  coef_dt <- coef_dt[GeneSymbol != "(Intercept)"]
  sel_dt <- coef_dt[Coef != 0]
  setorder(sel_dt, -abs(Coef))
  list(all = coef_dt, selected = sel_dt)
}

save_roc_plot <- function(roc_obj, file, title) {
  png(file, width = 900, height = 700)
  plot(roc_obj, main = title)
  dev.off()
}

save_coef_path <- function(cvfit, lambda_use, file) {
  png(file, width = 1100, height = 800)
  plot(cvfit$glmnet.fit, xvar = "lambda", label = FALSE, main = "Coefficient paths")
  abline(v = log(lambda_use), lty = 2)
  dev.off()
}
